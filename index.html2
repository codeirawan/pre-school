// ─────────────────────────────────────────────
let currentCategory = '';
let questions = [];
let currentQ = 0;
let score = 0;
let answered = false;

// Decorative stars
const starsEl = document.getElementById('stars');
['⭐','✨','🌟','💫'].forEach((e,_) => {
  for(let i=0;i<3;i++){
    const s=document.createElement('div'); s.className='star';
    s.textContent=e; s.style.left=Math.random()*100+'%'; s.style.top=Math.random()*55+'%';
    s.style.animationDelay=Math.random()*2+'s'; s.style.fontSize=(13+Math.random()*14)+'px';
    starsEl.appendChild(s);
  }
});

function shuffle(arr){ return [...arr].sort(()=>Math.random()-.5); }

function startQuiz(cat){
  currentCategory=cat;
  // For huruf/hijaiyah take all; others shuffle & cap at 15 for variety
  const data = quizData[cat];
  questions = shuffle(data).slice(0, Math.min(data.length, cat==='huruf'||cat==='hijaiyah' ? data.length : 15));
  currentQ=0; score=0; answered=false;
  document.getElementById('categoryScreen').style.display='none';
  document.getElementById('resultScreen').classList.remove('active');
  document.getElementById('quizScreen').classList.add('active');
  renderQuestion();
}

function renderQuestion(){
  answered=false;
  const q=questions[currentQ];
  const total=questions.length;
  document.getElementById('questionCounter').textContent=`Soal ${currentQ+1} / ${total}`;
  document.getElementById('scoreDisplay').textContent=score;
  document.getElementById('progressBar').style.width=`${((currentQ+1)/total)*100}%`;

  const iconEl=document.getElementById('questionIcon');
  const textEl=document.getElementById('questionText');

  // Render question card
  if(currentCategory==='huruf'){
    iconEl.innerHTML=`
      <div class="huruf-card">
        <div class="huruf-letter">${q.letter}</div>
        <div class="huruf-emoji">${q.emoji}</div>
      </div>
      <div class="huruf-word">${q.word}</div>`;
    textEl.textContent='Huruf apa ini?';
  } else if(currentCategory==='hijaiyah'){
    iconEl.innerHTML=`<span class="hijaiyah-arabic">${q.icon}</span>`;
    textEl.innerHTML=`Ini huruf hijaiyah apa? <span class="hijaiyah-hint">Baca namanya!</span>`;
  } else if(currentCategory==='angka'){
    iconEl.innerHTML=`<span style="font-size:clamp(18px,4vw,28px);line-height:1.6;word-break:break-all;display:block;max-width:280px;margin:0 auto;">${q.icon}</span>`;
    textEl.textContent='Ada berapa jumlahnya?';
  } else {
    iconEl.innerHTML=`<span style="font-size:clamp(68px,18vw,108px);line-height:1.1;display:block;margin-bottom:8px;filter:drop-shadow(0 4px 8px rgba(0,0,0,.15));animation:iconBounce 2s ease-in-out infinite">${q.icon}</span>`;
    textEl.textContent=q.text;
  }

  // Render choices
  const grid=document.getElementById('answersGrid');
  grid.innerHTML='';
  const choices = currentCategory==='huruf' ? shuffle(q.choices) : shuffle(q.choices);
  choices.forEach(c=>{
    const btn=document.createElement('button');
    btn.className='answer-btn';
    btn.innerHTML=`<span>${c}</span>`;
    btn.onclick=()=>checkAnswer(btn,c,q.answer);
    grid.appendChild(btn);
  });

  const card=document.getElementById('questionCard');
  card.style.animation='none'; card.offsetHeight;
  card.style.animation='slideIn .4s cubic-bezier(.34,1.56,.64,1)';
}

function checkAnswer(btn,chosen,correct){
  if(answered) return;
  answered=true;
  const allBtns=document.querySelectorAll('.answer-btn');
  allBtns.forEach(b=>b.disabled=true);
  if(chosen===correct){
    btn.classList.add('correct'); score++;
    showFeedback(true);
  } else {
    btn.classList.add('wrong');
    allBtns.forEach(b=>{ if(b.querySelector('span').textContent===correct) b.classList.add('correct'); });
    showFeedback(false);
  }
  document.getElementById('scoreDisplay').textContent=score;
  setTimeout(()=>{
    hideFeedback(); currentQ++;
    if(currentQ<questions.length) renderQuestion(); else showResult();
  },1300);
}

function showFeedback(ok){
  const overlay=document.getElementById('feedbackOverlay');
  const emoji=document.getElementById('feedbackEmoji');
  const text=document.getElementById('feedbackText');
  if(ok){
    emoji.textContent=['🎉','⭐','🌟','✨','🏆','🎊','👏','💫'][Math.floor(Math.random()*8)];
    text.textContent=['Benar! 🎉','Pintar! ⭐','Hebat!','Luar Biasa!','Keren! 🌟','Bagus Sekali!'][Math.floor(Math.random()*6)];
    text.className='feedback-text yay';
  } else {
    emoji.textContent=['😅','💪','🤔','😊','🌈','🫶'][Math.floor(Math.random()*6)];
    text.textContent=['Coba Lagi!','Hampir! 💪','Ayo Semangat!','Tetap Coba!','Belajar Lagi Yuk!'][Math.floor(Math.random()*5)];
    text.className='feedback-text oops';
  }
  overlay.classList.add('show');
}

function hideFeedback(){ document.getElementById('feedbackOverlay').classList.remove('show'); }

function showResult(){
  document.getElementById('quizScreen').classList.remove('active');
  const rs=document.getElementById('resultScreen');
  rs.classList.add('active');
  const total=questions.length;
  const pct=score/total;
  let star,title,msg,stars;
  if(pct===1)      { star='🏆'; title='Sempurna!';       msg='Kamu luar biasa hebat! 🌟🌟🌟'; stars=3; }
  else if(pct>=.8) { star='⭐'; title='Hebat Sekali!';   msg='Kamu sangat pintar! 🎉🎊';       stars=3; }
  else if(pct>=.6) { star='😊'; title='Bagus!';          msg='Terus belajar ya! 💪✨';         stars=2; }
  else if(pct>=.4) { star='🌈'; title='Ayo Coba Lagi!';  msg='Kamu pasti bisa lebih baik! 💫'; stars=1; }
  else             { star='💪'; title='Semangat!';        msg='Belajar lagi yuk, ayo! 🌟';      stars=1; }
  document.getElementById('resultStar').textContent=star;
  document.getElementById('resultTitle').textContent=title;
  document.getElementById('resultScore').textContent=score;
  document.getElementById('resultTotal').textContent=`dari ${total} soal benar`;
  document.getElementById('resultMsg').textContent=msg;
  document.getElementById('starsRow').innerHTML='⭐'.repeat(stars).split('').map((s,i)=>`<span class="star-item" style="animation-delay:${i*.15}s">${s}</span>`).join('');
  document.getElementById('replayBtn').onclick=()=>startQuiz(currentCategory);
  if(pct>=.6) confetti();
}

function goHome(){
  document.getElementById('quizScreen').classList.remove('active');
  document.getElementById('resultScreen').classList.remove('active');
  document.getElementById('categoryScreen').style.display='';
  hideFeedback();
}

function confetti(){
  const colors=['#FF6B6B','#FFD700','#4ECDC4','#FF69B4','#7DC95E','#9B59B6','#FF8C42','#3498DB'];
  for(let i=0;i<70;i++){
    const el=document.createElement('div');
    el.className='confetti-piece';
    el.style.left=Math.random()*100+'vw';
    el.style.background=colors[Math.floor(Math.random()*colors.length)];
    el.style.borderRadius=Math.random()>.5?'50%':'3px';
    el.style.width=el.style.height=(8+Math.random()*10)+'px';
    el.style.animationDuration=(1.5+Math.random()*2.5)+'s';
    el.style.animationDelay=Math.random()*.6+'s';
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),5000);
  }
}
</script>
</body>
</html>
